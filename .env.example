# --- Vite (фронт): подставляются при `npm run build` / `npm run dev` ---
# Mainnet Cyprus-1 = 9, Orchard Testnet = 15000 (должно совпадать с Pelagus)
VITE_QUAI_CHAIN_ID=9

# VITE_TAP_COUNTER_ADDRESS=0x...   # опционально; если задан — кнопка «Развернуть» в UI блокируется, пока не сбросишь привязку
# VITE_MINERS_ROOM_DONATE_ADDRESS=0x...   # контракт «Донат Miners Room»; иначе развёртывание из браузера
# VITE_QUAI_RPC_URL=https://rpc.quai.network/cyprus1

# Опционально: Demo API key CoinGecko (https://www.coingecko.com/en/api) — если публичный simple/price режется по лимитам
# VITE_COINGECKO_DEMO_API_KEY=

# --- Hardhat (как в https://github.com/dominant-strategies/hardhat-example ) ---
# Уникальный ключ для деплоя (в примере Quai — CYPRUS1_PK; поддерживается и PRIVATE_KEY)
# CYPRUS1_PK=0x...
# PRIVATE_KEY=0x...

# RPC для выбранной сети (`--network cyprus1` или `--network orchard`)
# В документации примера: RPC_URL; для совместимости можно QUAI_MAINNET_RPC / QUAI_RPC_URL
# RPC_URL=https://rpc.quai.network/cyprus1
# Для Orchard: RPC_URL=https://orchard.rpc.quai.network/cyprus1

# CHAIN_ID в официальном .env.dist задают под среду (local 1337, testnet 9000 и т.д.).
# В этом проекте chainId зашит в hardhat.config под именем сети: cyprus1 → 9, orchard → 15000.
